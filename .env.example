# ── Mandatory ─────────────────────────────────────────────────────────────────
# Get API_ID and API_HASH from https://my.telegram.org/apps
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# From @BotFather
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUVwxyz

# Run generate_session.py once to get this (see README)
SESSION_STRING=BQA...long_string...==

# Your Telegram numeric user ID (ask @userinfobot)
OWNER_ID=987654321

# ── Redis ──────────────────────────────────────────────────────────────────────
# Paste the Internal Redis URL from Render Key Value dashboard
REDIS_URL=redis://localhost:6379

# ── Optional ───────────────────────────────────────────────────────────────────
# Numeric ID of a channel for action logs (e.g. -1001234567890)
LOG_CHANNEL=

# Username (no @) or numeric ID of a channel users must join before using the bot
FORCE_SUB_CHANNEL=

# Your bot's username without @
BOT_USERNAME=SaveRestrictedBot

# ── Tunables (safe to leave as defaults) ───────────────────────────────────────
BATCH_MAX=50
AUTO_DELETE_DELAY=60
YTDLP_FORMAT=bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best
DOWNLOAD_DIR=/tmp/dl
PORT=8080
